# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_SETTINGS_MODULE=config.settings.dev

# GESP SSO JWT 共享密钥（与 GESP 的 DJANGO_SECRET_KEY 相同）
GESP_JWT_SECRET=

# Database (prod only)
DB_NAME=learning
DB_USER=learning
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Redis (prod only)
REDIS_URL=redis://127.0.0.1:6379/1

# CORS (prod only, comma-separated)
CORS_ORIGINS=https://learning.yusuan.xyz,https://yusuan.xyz

# Allowed hosts (prod only)
ALLOWED_HOSTS=learning.yusuan.xyz,127.0.0.1
